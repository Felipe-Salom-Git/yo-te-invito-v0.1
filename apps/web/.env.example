# apps/web/.env.example
NODE_ENV=development

# Public base URL for metadataBase, robots, sitemap, etc.
# Production:
#   NEXT_PUBLIC_APP_URL=https://yoteinvito.club
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Connection (API runs on port 3001 by default; sole data source)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Server-only: Getnet portal callback proxy (/api/getnet/callback → API webhook)
# Production: https://api.yoteinvito.club
# API_PUBLIC_URL=https://api.yoteinvito.club

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
# Generate a secret via: openssl rand -base64 32
NEXTAUTH_SECRET=placeholder_secret_here

# Auth Providers (Optional)
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx
# NEXT_PUBLIC_GOOGLE_ENABLED=true

# Web Push — misma clave pública que WEB_PUSH_VAPID_PUBLIC_KEY en API
# NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=

# Payment provider: DEMO (simulated) or GETNET (real). Default DEMO.
# NEXT_PUBLIC_PAYMENT_PROVIDER_DEFAULT=DEMO

# Google Maps (browser only) — prod key name: YTI Web Maps PROD; restrict by referrer in GCP.
# Do not commit real keys. See docs/deploy/GOOGLE_CLOUD_RUNBOOK.md §3.6
#
# Local / dev (optional — without key, LocationPickerMap uses manual fallback + OSM preview):
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
#
# Production VPS — set in /opt/yoteinvito/apps/web/.env.production (or env file used by yti-web):
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=<GOOGLE_MAPS_BROWSER_KEY_RESTRINGIDA>
