# apps/api/.env.example
# En local conviene `development` o dejar sin definir (no usar `production` salvo deploy real).
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/yo_te_invito?schema=public"

# CORS (comma-separated origins)
CORS_ORIGIN="http://localhost:3000,http://localhost:3002"

# Dev auth — set true to allow X-Dev-User-Id header for protected routes
# Header: X-Dev-User-Id: <user id from DB>
DEV_AUTH_ENABLED=false

# Authentication
# Generate a secret via: openssl rand -base64 32
JWT_SECRET=placeholder_secret_here

# Logging
LOG_LEVEL=debug

# Redis (Optional/Future)
# REDIS_URL=redis://localhost:6379

# Seed (optional — set to create default tenant + admin)
# SEED_DEFAULT_TENANT=true
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=changeme

# Emails — proveedor (MAIL_PROVIDER=smtp|resend)
# MAIL_PROVIDER=smtp
# MAIL_FROM="Yo Te Invito <no_reply@yoteinvito.club>"
# MAIL_REPLY_TO=soporte@yoteinvito.club
# MAIL_OPERATIONS_TO=operaciones@yoteinvito.club

# SMTP DonWeb (si MAIL_PROVIDER=smtp — secretos solo en servidor, no en git)
# SMTP_HOST=c2821613.ferozo.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=no_reply@yoteinvito.club
# SMTP_PASSWORD=

# Resend (si MAIL_PROVIDER=resend — rollback)
# RESEND_API_KEY=re_xxx

# Compat / transición
# EMAIL_FROM="Yo Te Invito <no_reply@yoteinvito.club>"
# ADMIN_EMAIL=operaciones@yoteinvito.club

# Smoke email (un destinatario explícito; no commitear passwords)
# SMOKE_EMAIL_TO=soporte@yoteinvito.club
# SMOKE_EMAIL_TEMPLATE_ID=AUTH_WELCOME_BUYER

# APP_URL=http://localhost:3000

# Redis (cola de emails — recomendado en prod)
# REDIS_URL=redis://localhost:6379

# Web Push (VAPID) — generar con: npx web-push generate-vapid-keys
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
# WEB_PUSH_CONTACT_EMAIL=mailto:support@yoteinvito.com

# Notificaciones portal (cron)
# APP_URL=http://localhost:3000
# NOTIFICATIONS_CRON_ENABLED=true
# NOTIFICATION_REMINDER_HOURS=24
# NOTIFICATION_REMINDER_TOLERANCE_HOURS=1

# Getnet Checkout — legacy GeoPagos Checkout API v2 (GETNET_CLIENT_*)
# Used when GETNET_WEBCHECKOUT_* is not configured.
# GETNET_ENV=staging
# GETNET_CLIENT_ID=your-client-id
# GETNET_CLIENT_SECRET=your-client-secret
# GETNET_SCOPE=*
# GETNET_AUTH_BASE_URL=   # optional override
# GETNET_CHECKOUT_BASE_URL=
# GETNET_WEBHOOK_SECRET=shared-secret-for-header
# GETNET_WEBHOOK_HEADER_NAME=x-getnet-webhook-secret
# GETNET_WEBHOOK_AUTH_MODE=header          # or basic for Web Checkout portal
# GETNET_WEBHOOK_BASIC_USER=
# GETNET_WEBHOOK_BASIC_PASSWORD=
# GETNET_WEBHOOK_REQUIRE_SECRET=true
# GETNET_RECONCILE_CONFIRM_PROD=yes   # required for payments:reconcile-getnet --confirm in prod
# WEB_APP_URL=https://yoteinvito.club   # return/cancel URLs in Payment.metadata
# API_PUBLIC_URL=https://api.yoteinvito.club
# SMOKE_GETNET_CONFIRM_PROD=yes         # smoke:getnet --simulate-webhook in prod only
# Verificar legacy: pnpm --filter api run smoke:getnet -- --config
#
# Getnet Web Checkout Redirect — GETNET_WEBCHECKOUT_* first, else GETNET_GLOBAL_* fallback
#
# Production (validated contract):
# GETNET_GLOBAL_ENV=production
# GETNET_GLOBAL_AUTH_BASE_URL=https://api.globalgetnet.com/authentication/oauth2/access_token
# GETNET_GLOBAL_WEBCHECKOUT_BASE_URL=https://api.globalgetnet.com/dpy/web-checkout/v1
# GETNET_GLOBAL_PAYMENT_INTENT_PATH=/payment-intent
# GETNET_GLOBAL_SELLER_ID=
# GETNET_GLOBAL_CLIENT_ID=
# GETNET_GLOBAL_SECRET_KEY=
# GETNET_GLOBAL_MERCHANT_ID=             # optional
#
# Or WEBCHECKOUT-prefixed equivalents:
# GETNET_WEBCHECKOUT_ENV=pre
# GETNET_WEBCHECKOUT_AUTH_BASE_URL=https://api.pre.globalgetnet.com/authentication/oauth2/access_token
# GETNET_WEBCHECKOUT_WEBCHECKOUT_BASE_URL=https://api.pre.globalgetnet.com/dpy/web-checkout/v1
# GETNET_WEBCHECKOUT_PAYMENT_INTENT_PATH=/payment-intent
# GETNET_WEBCHECKOUT_MERCHANT_ID=          # optional — x-merchant-id only when set
# GETNET_WEBCHECKOUT_SELLER_ID=            # required
# GETNET_WEBCHECKOUT_CLIENT_ID=            # required — OAuth body (not Basic Auth)
# GETNET_WEBCHECKOUT_SECRET_KEY=           # required — OAuth body
# GETNET_WEBCHECKOUT_CONFIRM_PRE=yes       # smoke live POST pre only
# GETNET_WEBCHECKOUT_CONFIRM_PROD=yes      # smoke live POST production only
# Legacy URL style (optional): GETNET_WEBCHECKOUT_API_BASE_URL + full PAYMENT_INTENT_PATH
# Verificar: pnpm --filter api run smoke:getnet-webcheckout -- --config

# Google Cloud Storage — uploads (optional in local dev; required for POST /uploads/public-image)
# GCS_PROJECT_ID=yoteinvito-1721413433327
# GCS_PRIVATE_BUCKET=yti-prod-storage
# GCS_PUBLIC_BUCKET=yti-prod-public-assets
# GCS_SERVICE_ACCOUNT_KEY_FILE=/absolute/path/to/gcp-yti-backend-storage.json
# GCS_PUBLIC_BASE_URL=https://storage.googleapis.com/yti-prod-public-assets
# GCS_SIGNED_URL_TTL_SECONDS=900
# UPLOAD_MAX_IMAGE_MB=5
# UPLOAD_ALLOWED_IMAGE_MIME_TYPES=image/jpeg,image/png,image/webp
