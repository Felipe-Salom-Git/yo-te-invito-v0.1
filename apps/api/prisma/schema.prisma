}

model TicketType {
  id               String           @id @default(cuid())
  tenantId         String
  eventId          String
  /// null = legacy single-date event; set for multi-date ticket types (V3.1 Etapa 7).
  occurrenceId     String?
  name             String
  description      String?
  price            Decimal          @db.Decimal(12, 2)
  currency         String           @default("ARS")
  capacityTotal    Int
  capacityAvailable Int
  maxPerOrder      Int              @default(10)
  salesStartAt     DateTime?
  salesEndAt       DateTime?
  status           TicketTypeStatus @default(ACTIVE)
  ticketTemplateId String?          @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  event          Event            @relation(fields: [eventId], references: [id])
  occurrence     EventOccurrence? @relation(fields: [occurrenceId], references: [id], onDelete: SetNull)
  ticketTemplate TicketTemplate?  @relation(fields: [ticketTemplateId], references: [id], onDelete: SetNull)
  batches        TicketBatch[]
  orderItems     OrderItem[]
  tickets        Ticket[]
  courtesyGrants CourtesyGrant[]
  userCartItems  UserCartItem[]
  dateChangesFrom TicketDateChangeRequest[] @relation("DateChangeFromTicketType")
  dateChangesTo   TicketDateChangeRequest[] @relation("DateChangeToTicketType")

  @@index([eventId, status])
  @@index([tenantId])
  @@index([occurrenceId])
}

/// Visual layout for digital ticket (producer canvas studio). QR payload at issuance is unchanged; this is display-only until a renderer consumes it.
model TicketTemplate {
  id              String   @id @default(cuid())
  tenantId        String
  name            String   @default("Diseño personalizado")
  canvasWidth     Int      @default(320)
  canvasHeight    Int      @default(560)
  backgroundType  String   @default("SOLID")
  backgroundValue String   @default("#0a0a0a")
  elementsJson    Json     @default("[]")
  qrZoneJson      Json
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  ticketType TicketType?

  @@index([tenantId])
}

model TicketBatch {
  id                 String             @id @default(cuid())
  tenantId           String
  eventId            String
  ticketTypeId       String
  orderIndex         Int
  name               String
  startAt            DateTime
  endAt              DateTime
  baseQuantity       Int
  rolloverQuantity   Int                @default(0)
  effectiveQuantity  Int
  reservedQuantity   Int                @default(0)
  soldCount          Int                @default(0)
  price              Decimal            @db.Decimal(12, 2)
  currency           String             @default("ARS")
  status             TicketBatchStatus  @default(SCHEDULED)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  tickets    Ticket[]

  @@unique([ticketTypeId, orderIndex])
  @@index([ticketTypeId])
  @@index([eventId])
  @@index([tenantId])
}

model Order {
  id              String      @id @default(cuid())
  tenantId        String
  eventId         String
  /// Selected date for multi-date events (V3.1 Etapa 7).
  occurrenceId    String?
  status          OrderStatus @default(PENDING_PAYMENT)
  buyerEmail      String
  buyerFirstName  String
  buyerLastName   String
  buyerDocument   String?
  /// When set at checkout, tickets assign to this user even if buyerEmail casing differs from User.email lookup.
  buyerUserId     String?
  totalAmount     Decimal     @db.Decimal(12, 2)
  currency        String      @default("ARS")
  expiresAt       DateTime?
  expiredAt       DateTime?
  paidAt          DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  event          Event       @relation(fields: [eventId], references: [id])
  occurrence     EventOccurrence? @relation(fields: [occurrenceId], references: [id], onDelete: SetNull)
  buyerUser      User?       @relation("OrderBuyer", fields: [buyerUserId], references: [id], onDelete: SetNull)
  orderItems     OrderItem[]
  tickets        Ticket[]
  payments       Payment[]
  referralLink   ReferralLink?  @relation(fields: [referralLinkId], references: [id])
  referralLinkId String?

  @@index([tenantId, buyerEmail])
  @@index([tenantId, eventId])
  @@index([tenantId, status])
  @@index([expiresAt])
  @@index([buyerUserId])
  @@index([occurrenceId])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  ticketTypeId   String
  ticketBatchId  String?
  occurrenceId   String?
  quantity       Int
  unitPrice      Decimal  @db.Decimal(12, 2)
  subtotal       Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  order        Order         @relation(fields: [orderId], references: [id])
  ticketType   TicketType    @relation(fields: [ticketTypeId], references: [id])
  ticketBatch  TicketBatch?  @relation(fields: [ticketBatchId], references: [id])
  occurrence   EventOccurrence? @relation(fields: [occurrenceId], references: [id], onDelete: SetNull)
  tickets      Ticket[]

  @@index([ticketBatchId])
  @@index([occurrenceId])
}

enum ScanResult {
  OK
  ALREADY_USED
  INVALID
  REVOKED
}

enum TicketSource {
  ORDER
  COURTESY
}

enum CourtesyMode {
  CONSUMES_BATCH
  FREE_CAPACITY
}

model CourtesyGrant {
  id           String       @id @default(cuid())
  tenantId     String
  eventId      String
  ticketTypeId String?
  mode         CourtesyMode
  quantity     Int
  issued       Int          @default(0)
  note         String?
  createdById  String
  createdAt    DateTime     @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  event       Event       @relation(fields: [eventId], references: [id])
  ticketType  TicketType? @relation(fields: [ticketTypeId], references: [id])
  createdBy   User        @relation(fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([eventId])
}

model Ticket {
  id               String       @id @default(cuid())
  orderId          String?
  orderItemId      String?
  ticketTypeId     String?
  ticketBatchId    String?
  occurrenceId     String?
  eventId          String
  qrPayload        String       @unique
  status           TicketStatus @default(VALID)
  source           TicketSource @default(ORDER)
  ownerUserId      String?
  usedAt           DateTime?
  revokedAt        DateTime?
  revokedByUserId  String?
  revokedReason    String?
  revokedNote      String?
  transferredFromTicketId String?
  activeTransferOfferId   String?      @unique
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  order          Order?           @relation(fields: [orderId], references: [id])
  orderItem      OrderItem?       @relation(fields: [orderItemId], references: [id])
  ticketType     TicketType?      @relation(fields: [ticketTypeId], references: [id])
  ticketBatch    TicketBatch?     @relation(fields: [ticketBatchId], references: [id])
  occurrence     EventOccurrence? @relation(fields: [occurrenceId], references: [id], onDelete: SetNull)
  event          Event            @relation(fields: [eventId], references: [id])
  ownerUser      User?            @relation("TicketOwner", fields: [ownerUserId], references: [id])
  transferredFromTicket   Ticket?  @relation("TicketTransferLineage", fields: [transferredFromTicketId], references: [id], onDelete: SetNull)
  transferredToTickets    Ticket[] @relation("TicketTransferLineage")
  activeTransferOffer     TicketTransferOffer? @relation("ActiveTransferOnTicket", fields: [activeTransferOfferId], references: [id], onDelete: SetNull)
  destinationTransferOffer TicketTransferOffer? @relation("TransferOfferDestinationTicket")
  ticketScans    TicketScan[]
  ticketScanLogs TicketScanLog[]
  transfers      TicketTransfer[]
  transferOffers TicketTransferOffer[] @relation("TransferOfferSourceTicket")
  dateChangeRequests TicketDateChangeRequest[]

  @@index([eventId, status])
  @@index([orderId])
  @@index([ownerUserId])
  @@index([ticketBatchId])
  @@index([occurrenceId])
}

model TicketDateChangeRequest {
  id                String                        @id @default(cuid())
  tenantId          String
  ticketId          String
  requestedByUserId String
  fromOccurrenceId  String
  toOccurrenceId    String
  fromTicketTypeId  String?
  toTicketTypeId    String?
  status            TicketDateChangeRequestStatus @default(PENDING)
  message           String?
  rejectReason      String?
  reviewedByUserId  String?
  reviewedAt        DateTime?
  appliedAt         DateTime?
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  ticket         Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  requestedBy    User            @relation("TicketDateChangeRequester", fields: [requestedByUserId], references: [id])
  reviewedBy     User?           @relation("TicketDateChangeReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  fromOccurrence EventOccurrence @relation("DateChangeFromOccurrence", fields: [fromOccurrenceId], references: [id])
  toOccurrence   EventOccurrence @relation("DateChangeToOccurrence", fields: [toOccurrenceId], references: [id])
  fromTicketType TicketType?     @relation("DateChangeFromTicketType", fields: [fromTicketTypeId], references: [id], onDelete: SetNull)
  toTicketType   TicketType?     @relation("DateChangeToTicketType", fields: [toTicketTypeId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([ticketId])
  @@index([ticketId, status])
  @@index([tenantId, status])
  @@index([fromOccurrenceId])
  @@index([toOccurrenceId])
}

model TicketTransfer {
  id                  String   @id @default(cuid())
  ticketId            String
  offerId             String?
  destinationTicketId String?
  fromUserId          String
  toUserId            String
  idempotencyKey      String?
  createdAt           DateTime @default(now())

  ticket            Ticket              @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  offer             TicketTransferOffer? @relation(fields: [offerId], references: [id], onDelete: SetNull)
  fromUser          User                @relation("TransferFromUser", fields: [fromUserId], references: [id])
  toUser            User                @relation("TransferToUser", fields: [toUserId], references: [id])

  @@index([ticketId])
  @@index([ticketId, idempotencyKey])
  @@index([offerId])
}

model TicketTransferOffer {
  id                  String                    @id @default(cuid())
  tenantId            String
  sourceTicketId      String
  destinationTicketId String?                   @unique
  sellerUserId        String
  buyerUserId         String?
  status              TicketTransferOfferStatus @default(AVAILABLE)
  acceptToken         String                    @unique
  expiresAt           DateTime
  reservedAt          DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  rejectedAt          DateTime?
  message             String?
  idempotencyKey      String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  tenant            Tenant           @relation(fields: [tenantId], references: [id])
  sourceTicket      Ticket           @relation("TransferOfferSourceTicket", fields: [sourceTicketId], references: [id], onDelete: Cascade)
  destinationTicket Ticket?          @relation("TransferOfferDestinationTicket", fields: [destinationTicketId], references: [id], onDelete: SetNull)
  sellerUser        User             @relation("TransferOfferSeller", fields: [sellerUserId], references: [id])
  buyerUser         User?            @relation("TransferOfferBuyer", fields: [buyerUserId], references: [id], onDelete: SetNull)
  activeOnTicket    Ticket?          @relation("ActiveTransferOnTicket")
  transferLogs      TicketTransfer[]

  @@index([tenantId, sellerUserId, status])
  @@index([tenantId, buyerUserId, status])
  @@index([sourceTicketId, status])
  @@index([expiresAt])
}

model UserNotification {
