// Prisma schema — Yo Te Invito
// Slice 02: Tenant + User + RBAC
// Slice 02: Tenant + User + RBAC

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PRODUCER_OWNER
  PRODUCER_STAFF
  GASTRO_OWNER
  REFERRER
  SCANNER
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

// ─── Operational profiles (single user + profiles model) ─────────────────────
enum ProfileStatus {
  DRAFT
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
}

enum MembershipRole {
  OWNER
  ADMIN
  STAFF
}

enum MembershipStatus {
  ACTIVE
  PENDING
  DISABLED
}

model Tenant {
  id        String    @id @default(cuid())
  name      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users          User[]
  events         Event[]
  orders         Order[]
  ticketScans         TicketScan[]
  ticketScanLogs      TicketScanLog[]
  courtesyGrants    CourtesyGrant[]
  referralLinks     ReferralLink[]
  referralAttributions ReferralAttribution[]
  referralCommissions ReferralCommission[]
  reviews             Review[]
  auditLogs           AuditLog[]
  fraudSignals        FraudSignal[]
  payouts             Payout[]
  platformConfig      PlatformConfig?
  roleApplications    RoleApplication[]
  producerProfiles    ProducerProfile[]
  gastroProfiles      GastroProfile[]
  referrerProfiles    ReferrerProfile[]
  userProducerMemberships UserProducerMembership[]
  userGastroMemberships   UserGastroMembership[]
  userReferrerMemberships UserReferrerMembership[]
}

model ProducerProfile {
  id               String        @id @default(cuid())
  tenantId         String
  slug             String?       @unique
  displayName      String
  legalName        String?
  shortDescription String?
  longDescription  String?
  logoUrl          String?
  coverImageUrl    String?
  primaryPhone     String?
  secondaryPhone   String?
  primaryEmail     String?
  secondaryEmail   String?
  whatsapp         String?
  city             String?
  country          String?
  socialLinks      Json?
  ratingAvg        Float?
  ratingCount      Int           @default(0)
  createdByUserId  String?
  status           ProfileStatus @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant     Tenant                    @relation(fields: [tenantId], references: [id])
  memberships UserProducerMembership[]
  events     Event[]
  referrerRelationships ProducerReferrerRelationship[]
  eventReferrerAssignments EventReferrerAssignment[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model GastroProfile {
  id              String        @id @default(cuid())
  tenantId        String
  displayName     String
  legalName       String?
  description     String?
  logoUrl         String?
  bannerUrl       String?
  address         String?
  city            String?
  contactPhone    String?
  ratingAvg       Float?
  ratingCount     Int           @default(0)
  createdByUserId String?
  status          ProfileStatus @default(DRAFT)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant     Tenant                  @relation(fields: [tenantId], references: [id])
  memberships UserGastroMembership[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model ReferrerProfile {
  id              String        @id @default(cuid())
  tenantId        String
  displayName     String
  publicHandle    String?
  bio             String?
  avatarUrl       String?
  salesScore      Float?
  completedSales  Int           @default(0)
  createdByUserId String?
  status          ProfileStatus @default(DRAFT)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant     Tenant                     @relation(fields: [tenantId], references: [id])
  memberships UserReferrerMembership[]
  referralLinks ReferralLink[]
  producerRelationships ProducerReferrerRelationship[]
  eventAssignments EventReferrerAssignment[]

  @@index([tenantId])
  @@index([tenantId, status])
}

enum RelationshipStatus {
  PENDING
  ACTIVE
  REJECTED
  BLOCKED
}

enum RelationshipOrigin {
  REQUESTED_BY_REFERRER
  INVITED_BY_PRODUCER
  FREELANCE_CONTACT
}

model ProducerReferrerRelationship {
  id                String             @id @default(cuid())
  producerProfileId String
  referrerProfileId String
  status            RelationshipStatus @default(PENDING)
  origin            RelationshipOrigin @default(REQUESTED_BY_REFERRER)
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  producerProfile ProducerProfile @relation(fields: [producerProfileId], references: [id], onDelete: Cascade)
  referrerProfile ReferrerProfile @relation(fields: [referrerProfileId], references: [id], onDelete: Cascade)

  @@unique([producerProfileId, referrerProfileId])
  @@index([producerProfileId])
  @@index([referrerProfileId])
}

enum EventAssignmentStatus {
  ACTIVE
  PAUSED
  CANCELED
}

model EventReferrerAssignment {
  id                 String                @id @default(cuid())
  eventId            String
  producerProfileId  String
  referrerProfileId  String
  referralLinkId     String?               @unique
  courtesyQuota      Int                   @default(0)
  courtesyUsedCount  Int                   @default(0)
  salesScoreSnapshot Float?
  status             EventAssignmentStatus @default(ACTIVE)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  event           Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  producerProfile ProducerProfile @relation(fields: [producerProfileId], references: [id], onDelete: Cascade)
  referrerProfile ReferrerProfile @relation(fields: [referrerProfileId], references: [id], onDelete: Cascade)
  referralLink    ReferralLink?   @relation(fields: [referralLinkId], references: [id])

  @@unique([eventId, producerProfileId, referrerProfileId])
  @@index([eventId])
  @@index([producerProfileId])
  @@index([referrerProfileId])
}

model UserProducerMembership {
  id           String           @id @default(cuid())
  tenantId     String
  userId       String
  profileId    String
  membershipRole MembershipRole @default(OWNER)
  status       MembershipStatus @default(ACTIVE)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile ProducerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([userId, profileId])
  @@index([tenantId])
  @@index([userId])
  @@index([profileId])
}

model UserGastroMembership {
  id             String           @id @default(cuid())
  tenantId       String
  userId         String
  profileId      String
  membershipRole MembershipRole   @default(OWNER)
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  tenant  Tenant        @relation(fields: [tenantId], references: [id])
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile GastroProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([userId, profileId])
  @@index([tenantId])
  @@index([userId])
  @@index([profileId])
}

model UserReferrerMembership {
  id             String           @id @default(cuid())
  tenantId       String
  userId         String
  profileId      String
  membershipRole MembershipRole   @default(OWNER)
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  tenant  Tenant          @relation(fields: [tenantId], references: [id])
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile ReferrerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([userId, profileId])
  @@index([tenantId])
  @@index([userId])
  @@index([profileId])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model RoleApplication {
  id                String            @id @default(cuid())
  tenantId          String
  email             String
  passwordHash      String
  firstName         String
  lastName          String
  phone             String?
  businessName      String?
  role              Role              // PRODUCER_OWNER | GASTRO_OWNER
  status            ApplicationStatus @default(PENDING)
  createdAt         DateTime          @default(now())
  reviewedAt        DateTime?
  reviewedByUserId  String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([expiresAt])
}

model PlatformConfig {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactEmail    String?
  contactPhone    String?
  contactAddress  String?
  categories      Json?    // [{id: string, label: string}, ...]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id           String      @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String?
  firstName    String
  lastName     String
  phone        String?
  role         Role
  status       UserStatus
  preferences  Json?
  emailVerified DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  courtesyGrants    CourtesyGrant[]
  referralLinks     ReferralLink[]
  referralCommissions ReferralCommission[]
  reviews           Review[]
  ownedTickets       Ticket[]         @relation("TicketOwner")
  transfersFrom      TicketTransfer[] @relation("TransferFromUser")
  transfersTo        TicketTransfer[] @relation("TransferToUser")
  producerMemberships UserProducerMembership[]
  gastroMemberships   UserGastroMembership[]
  referrerMemberships UserReferrerMembership[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, role])
}

enum EventStatus {
  DRAFT
  PENDING
  APPROVED
  PAUSED
  CANCELLED
}

enum EventMediaType {
  IMAGE
  VIDEO
}

model Event {
  id                String       @id @default(cuid())
  tenantId          String
  producerId        String       // LEGACY: kept for compatibility; prefer producerProfileId
  producerProfileId String?      // ownership via ProducerProfile
  category          String?      // event | gastro | excursion | rental — for catalog display
  title             String
  description       String?
  startAt           DateTime
  endAt             DateTime?
  city              String?
  venueName         String?
  venueAddress      String?
  geoLat            Float?
  geoLng            Float?
  status            EventStatus  @default(DRAFT)
  capacityTotal     Int?
  coverImageUrl     String?
  isTicketingEnabled Boolean     @default(false)
  ratingAvg         Float?
  ratingCount       Int          @default(0)
  publishedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  producerProfile ProducerProfile? @relation(fields: [producerProfileId], references: [id], onDelete: SetNull)
  media       EventMedia[]
  ticketTypes     TicketType[]
  tickets         Ticket[]
  ticketScans     TicketScan[]
  ticketScanLogs  TicketScanLog[]
  orders           Order[]
  courtesyGrants      CourtesyGrant[]
  referralLinks       ReferralLink[]
  referralAttributions ReferralAttribution[]
  referralCommissions  ReferralCommission[]
  referrerAssignments  EventReferrerAssignment[]
  reviews             Review[]
  fraudSignals        FraudSignal[]
  payouts             Payout[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, status, deletedAt, startAt])
  @@index([tenantId, city])
  @@index([producerProfileId])
}

enum TicketTypeStatus {
  ACTIVE
  PAUSED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CANCELLED
  EXPIRED
  REFUNDED
}

enum TicketStatus {
  VALID
  USED
  REVOKED
}

enum PaymentProvider {
  DEMO
  MERCADOPAGO
  GETNET
}

enum PaymentStatus {
  CREATED
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model TicketType {
  id               String           @id @default(cuid())
  eventId          String
  name             String
  description      String?
  price            Decimal          @db.Decimal(12, 2)
  currency         String           @default("ARS")
  capacityTotal    Int
  capacityAvailable Int
  maxPerOrder      Int              @default(10)
  salesStartAt     DateTime?
  salesEndAt       DateTime?
  status           TicketTypeStatus @default(ACTIVE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  event          Event          @relation(fields: [eventId], references: [id])
  orderItems     OrderItem[]
  tickets        Ticket[]
  courtesyGrants CourtesyGrant[]

  @@index([eventId, status])
}

model Order {
  id              String      @id @default(cuid())
  tenantId        String
  eventId         String
  status          OrderStatus @default(PENDING_PAYMENT)
  buyerEmail      String
  buyerFirstName  String
  buyerLastName   String
  buyerDocument   String?
  totalAmount     Decimal     @db.Decimal(12, 2)
  currency        String      @default("ARS")
  expiresAt       DateTime?
  expiredAt       DateTime?
  paidAt          DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  event          Event       @relation(fields: [eventId], references: [id])
  orderItems     OrderItem[]
  tickets        Ticket[]
  payments       Payment[]
  referralLink   ReferralLink?  @relation(fields: [referralLinkId], references: [id])
  referralLinkId String?

  @@index([tenantId, buyerEmail])
  @@index([tenantId, eventId])
  @@index([tenantId, status])
  @@index([expiresAt])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  ticketTypeId String
  quantity     Int
  unitPrice    Decimal  @db.Decimal(12, 2)
  subtotal     Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  order      Order       @relation(fields: [orderId], references: [id])
  ticketType TicketType  @relation(fields: [ticketTypeId], references: [id])
  tickets    Ticket[]
}

enum ScanResult {
  OK
  ALREADY_USED
  INVALID
  REVOKED
}

enum TicketSource {
  ORDER
  COURTESY
}

enum CourtesyMode {
  CONSUMES_BATCH
  FREE_CAPACITY
}

model CourtesyGrant {
  id           String       @id @default(cuid())
  tenantId     String
  eventId      String
  ticketTypeId String?
  mode         CourtesyMode
  quantity     Int
  issued       Int          @default(0)
  note         String?
  createdById  String
  createdAt    DateTime     @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  event       Event       @relation(fields: [eventId], references: [id])
  ticketType  TicketType? @relation(fields: [ticketTypeId], references: [id])
  createdBy   User        @relation(fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([eventId])
}

model Ticket {
  id               String       @id @default(cuid())
  orderId          String?
  orderItemId      String?
  ticketTypeId     String?
  eventId          String
  qrPayload        String       @unique
  status           TicketStatus @default(VALID)
  source           TicketSource @default(ORDER)
  ownerUserId      String?
  usedAt           DateTime?
  revokedAt        DateTime?
  revokedByUserId  String?
  revokedReason    String?
  revokedNote      String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  order          Order?           @relation(fields: [orderId], references: [id])
  orderItem      OrderItem?       @relation(fields: [orderItemId], references: [id])
  ticketType     TicketType?      @relation(fields: [ticketTypeId], references: [id])
  event          Event            @relation(fields: [eventId], references: [id])
  ownerUser      User?            @relation("TicketOwner", fields: [ownerUserId], references: [id])
  ticketScans    TicketScan[]
  ticketScanLogs TicketScanLog[]
  transfers      TicketTransfer[]

  @@index([eventId, status])
  @@index([orderId])
  @@index([ownerUserId])
}

model TicketTransfer {
  id             String   @id @default(cuid())
  ticketId       String
  fromUserId     String
  toUserId       String
  idempotencyKey String?
  createdAt      DateTime @default(now())

  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromUser  User   @relation("TransferFromUser", fields: [fromUserId], references: [id])
  toUser    User   @relation("TransferToUser", fields: [toUserId], references: [id])

  @@index([ticketId])
  @@index([ticketId, idempotencyKey])
}

model TicketScan {
  id        String   @id @default(cuid())
  tenantId  String
  eventId   String
  ticketId  String?
  qrPayload String
  deviceId  String?
  ipAddress String?
  userAgent String?
  isValid   Boolean
  reason    String
  createdAt DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  event  Event   @relation(fields: [eventId], references: [id])
  ticket Ticket? @relation(fields: [ticketId], references: [id])

  @@index([tenantId])
  @@index([eventId])
  @@index([ticketId])
  @@index([tenantId, createdAt])
  @@index([eventId, createdAt])
}

model FraudSignal {
  id          String   @id @default(cuid())
  tenantId    String
  eventId     String
  signalType  String
  deviceId    String?
  ipAddress   String?
  scanCount   Int
  windowStart DateTime
  windowEnd   DateTime
  metadata    Json?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  event  Event  @relation(fields: [eventId], references: [id])

  @@index([tenantId])
  @@index([eventId])
  @@index([eventId, createdAt])
  @@index([eventId, signalType])
}

model TicketScanLog {
  id        String     @id @default(cuid())
  tenantId  String
  eventId   String
  ticketId  String?
  qrPayload String
  deviceId  String?
  scannerId String?
  result    ScanResult
  createdAt DateTime  @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  event  Event   @relation(fields: [eventId], references: [id])
  ticket Ticket? @relation(fields: [ticketId], references: [id])

  @@index([tenantId])
  @@index([eventId])
  @@index([ticketId])
}

enum PayoutStatus {
  REQUESTED
  PENDING
  PROCESSING
  SENT
  REJECTED
}

model Payout {
  id               String      @id @default(cuid())
  tenantId         String
  eventId          String
  producerId       String      // LEGACY: User.id; prefer producerProfileId
  producerProfileId String?    // ownership via ProducerProfile
  status           PayoutStatus @default(REQUESTED)
  amountCents      Int
  bankInfo         Json?
  requestedByUserId String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  event  Event  @relation(fields: [eventId], references: [id])

  @@index([tenantId])
  @@index([eventId])
  @@index([producerId])
}

model Payment {
  id                String          @id @default(cuid())
  tenantId          String
  orderId           String
  provider          PaymentProvider
  status            PaymentStatus
  amount            Int
  currency          String          @default("ARS")
  externalPaymentId String?
  externalReference String?
  paymentUrl        String?
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([tenantId])
  @@index([orderId])
  @@index([provider])
}

model EventMedia {
  id        String         @id @default(cuid())
  eventId   String
  type      EventMediaType
  url       String
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  deletedAt DateTime?

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
}

enum ReferralCommissionStatus {
  PENDING
  REQUESTED
  PAID
  REJECTED
}

model ReferralCommission {
  id                String                   @id @default(cuid())
  tenantId          String
  referrerId        String
  referralLinkId    String
  eventId           String
  amountCents       Int
  status            ReferralCommissionStatus @default(PENDING)
  requestedAt       DateTime?
  paidAt            DateTime?
  confirmedByUserId String?

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  referrer     User         @relation(fields: [referrerId], references: [id])
  referralLink ReferralLink @relation(fields: [referralLinkId], references: [id])
  event        Event        @relation(fields: [eventId], references: [id])

  @@index([tenantId])
  @@index([referrerId])
  @@index([eventId])
}

model ReferralLink {
  id        String   @id @default(cuid())
  tenantId  String
  eventId   String
  code      String   @unique
  referrerId  String?       // LEGACY: User.id; prefer referrerProfileId
  referrerProfileId String? // ownership via ReferrerProfile
  label     String?
  createdAt DateTime @default(now())

  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  event        Event               @relation(fields: [eventId], references: [id])
  referrer     User?               @relation(fields: [referrerId], references: [id])
  referrerProfile ReferrerProfile? @relation(fields: [referrerProfileId], references: [id], onDelete: SetNull)
  orders       Order[]
  attributions ReferralAttribution[]
  commissions  ReferralCommission[]
  eventAssignment EventReferrerAssignment?

  @@index([tenantId])
  @@index([eventId])
  @@index([referrerId])
  @@index([referrerProfileId])
}

model ReferralAttribution {
  id            String   @id @default(cuid())
  tenantId      String
  eventId       String
  referralLinkId String
  orderId       String   @unique
  attributedAt  DateTime @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  event        Event        @relation(fields: [eventId], references: [id])
  referralLink ReferralLink @relation(fields: [referralLinkId], references: [id])

  @@index([tenantId])
  @@index([eventId])
  @@index([referralLinkId])
}

enum AuditAction {
  EVENT_APPROVED
  TICKET_REVOKED
  ORDER_EXPIRED
  TICKET_TRANSFERRED
  PAYOUT_STATUS_CHANGED
}

model AuditLog {
  id         String      @id @default(cuid())
  tenantId   String
  actorId    String
  actorRole  String
  action     AuditAction
  entityType String
  entityId   String
  before     Json?
  after      Json?
  metadata   Json?
  createdAt  DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model Review {
  id        String   @id @default(cuid())
  tenantId  String
  eventId   String
  userId    String
  score     Int
  title     String?
  comment   String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  event  Event  @relation(fields: [eventId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([tenantId])
  @@index([eventId])
}
