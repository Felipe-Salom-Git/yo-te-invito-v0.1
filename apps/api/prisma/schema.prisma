/// Scanner user bound to one parent commercial account (tenant-scoped).
model ScannerAccount {
  id                String                   @id @default(cuid())
  tenantId          String
  scannerUserId     String                   @unique
  parentUserId      String
  parentProfileType ScannerParentProfileType
  parentProfileId   String
  isActive          Boolean                  @default(true)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scannerUser User   @relation("ScannerAccountScanner", fields: [scannerUserId], references: [id], onDelete: Cascade)
  parentUser  User   @relation("ScannerAccountParent", fields: [parentUserId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, parentProfileType, parentProfileId])
  @@index([tenantId, parentUserId])
}

model AuditLog {
  id         String      @id @default(cuid())
  tenantId   String
  actorId    String
  actorRole  String
  action     AuditAction
  entityType String
  entityId   String
  before     Json?
  after      Json?
  metadata   Json?
  createdAt  DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model Review {
  id                 String    @id @default(cuid())
  tenantId           String
  eventId            String
  userId             String?
  /// Legacy 1–5 score; kept for backward compatibility. New reviews sync from overallRating.
  score              Int
  /// V2 overall score 1–10
  overallRating      Int?
  /// V2 per-aspect scores keyed by aspect id (JSON)
  aspectRatings      Json?
  title              String?
  comment            String?
  /// Display name when userId is null (valoración sin cuenta)
  guestName          String?
  status             ReviewPublicStatus @default(VISIBLE)
  hiddenFromPublic   Boolean   @default(false)
  isVerified         Boolean   @default(false)
  hiddenReason       String?
  hiddenAt           DateTime?
  hiddenByUserId     String?
  officialReply      String?
  replyAuthorType    ReviewReplyAuthorType?
  replyAuthorId      String?
  replyCreatedAt     DateTime?
  replyUpdatedAt     DateTime?
  moderatedAt        DateTime?
  moderatedByUserId  String?
  createdAt          DateTime  @default(now())

  tenant      Tenant @relation(fields: [tenantId], references: [id])
  event       Event  @relation(fields: [eventId], references: [id])
  user        User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  moderatedBy User?  @relation("ReviewModerator", fields: [moderatedByUserId], references: [id], onDelete: SetNull)
  hiddenBy    User?  @relation("ReviewHiddenBy", fields: [hiddenByUserId], references: [id], onDelete: SetNull)
  disputeRequests ReviewDisputeRequest[]

  @@unique([eventId, userId])
  @@index([tenantId])
  @@index([eventId])
  @@index([eventId, status])
  @@index([userId, status])
  @@index([moderatedByUserId])
}

model ReviewDisputeRequest {
  id                String                 @id @default(cuid())
  tenantId          String
  reviewId          String
  producerProfileId String
  eventId           String
  requestedByUserId String
  reasonType        ReviewDisputeReasonType
  message           String
  status            ReviewDisputeStatus    @default(PENDING)
  adminNote         String?
  resolvedByUserId  String?
  resolvedAt        DateTime?
  inboxItemId       String?                @unique
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  review          Review          @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  producerProfile ProducerProfile @relation(fields: [producerProfileId], references: [id], onDelete: Cascade)
  event           Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  requestedBy     User            @relation("ReviewDisputeRequester", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  resolvedBy      User?           @relation("ReviewDisputeResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  inboxItem       InboxItem?      @relation(fields: [inboxItemId], references: [id], onDelete: SetNull)

  @@index([tenantId, producerProfileId])
  @@index([tenantId, reviewId])
  @@index([tenantId, status])
}

model InboxItem {
  id               String          @id @default(cuid())
  tenantId         String
  kind             InboxItemKind
  status           InboxItemStatus @default(PENDING)
  createdByUserId  String
  assigneeRole     Role            @default(ADMIN)
  title            String
  summary          String?
  payload          Json
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  resolvedAt       DateTime?
  resolvedByUserId String?
  resolutionNote   String?

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  creator  User   @relation("InboxItemCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  resolver User?  @relation("InboxItemResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  reviewDisputeRequest ReviewDisputeRequest?

  @@index([tenantId, status, kind])
  @@index([tenantId, status])
  @@index([createdByUserId])
}

model GastroDiscount {
  id                String               @id @default(cuid())
  tenantId          String
  eventId           String
  gastroProfileId   String?
  code              String
  type              GastroDiscountType
  value             Float
  validFrom         DateTime?
  validTo           DateTime?
  discountDate      DateTime?
  status            GastroDiscountStatus @default(PENDING_REVIEW)
  displayTitle      String?
  summary           String?
  detail            String?
  displayDescription String?
  displayImageUrls  Json?
  submittedImageUrls Json?
  qrToken           String?
  qrGeneratedAt     DateTime?
  emailSentAt       DateTime?
  emailSendError    String?
  lastEmailAttemptAt DateTime?
  adminNotes        String?
  rejectionReason   String?
  commissionCoordinationAcceptedAt DateTime?
  sourceInboxItemId String?              @unique
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  tenant        Tenant                  @relation(fields: [tenantId], references: [id])
  event         Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  gastroProfile GastroProfile?          @relation(fields: [gastroProfileId], references: [id], onDelete: SetNull)
  validations   GastroDiscountValidation[]
  claims        GastroDiscountClaim[]

  @@unique([eventId, code])
  @@index([tenantId, eventId])
  @@index([tenantId, status])
  @@index([gastroProfileId, status])
}

model GastroDiscountValidation {
  id          String   @id @default(cuid())
  discountId  String
  claimId     String?  @unique
  validatedAt DateTime @default(now())
  userId      String?
  orderId     String?

  discount GastroDiscount      @relation(fields: [discountId], references: [id], onDelete: Cascade)
  claim    GastroDiscountClaim? @relation(fields: [claimId], references: [id], onDelete: SetNull)

  @@index([discountId])
}

model GastroDiscountClaim {
  id             String    @id @default(cuid())
  tenantId       String
  discountId     String
  userId         String?
  email          String
  qrToken        String    @unique
  accessToken    String    @unique
  emailSentAt    DateTime?
  emailSendError String?
  createdAt      DateTime  @default(now())

  tenant       Tenant                     @relation(fields: [tenantId], references: [id])
  discount     GastroDiscount             @relation(fields: [discountId], references: [id], onDelete: Cascade)
  user         User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  validations  GastroDiscountValidation[]

  @@unique([discountId, email])
  @@index([tenantId, discountId])
  @@index([userId])
}

// ─── Legal documents (administrable TyC / policies) ───────────────────────────

enum LegalDocumentVisibility {
  PUBLIC
  INTERNAL
}

enum LegalDocumentVersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LegalAcceptanceContext {
  SIGNUP
  CHECKOUT
  PROFILE_ONBOARDING
  PORTAL_ACCESS
}

model LegalDocument {
  id                        String                  @id @default(cuid())
  tenantId                  String
  key                       String
  title                     String
  description               String?
  visibility                LegalDocumentVisibility @default(PUBLIC)
  appliesToProfiles         String[]                @default([])
  isRequiredForSignup       Boolean                 @default(false)
  isRequiredForCheckout     Boolean                 @default(false)
  isRequiredForPortalAccess   Boolean                 @default(false)
  isActive                  Boolean                 @default(true)
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions    LegalDocumentVersion[]
  acceptances UserLegalAcceptance[]

  @@unique([tenantId, key])
  @@index([tenantId, visibility])
  @@index([tenantId, isActive])
}

model LegalDocumentVersion {
  id                  String                     @id @default(cuid())
  documentId          String
  version             String
  status              LegalDocumentVersionStatus @default(DRAFT)
  title               String
  contentMarkdown     String                     @db.Text
  summary             String?
  publishedAt         DateTime?
  publishedByUserId   String?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  document    LegalDocument         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  publishedBy User?                 @relation("LegalVersionPublisher", fields: [publishedByUserId], references: [id], onDelete: SetNull)
  acceptances UserLegalAcceptance[]

  @@unique([documentId, version])
  @@index([documentId, status])
}

model UserLegalAcceptance {
  id                String                 @id @default(cuid())
  userId            String
  documentId        String
  documentVersionId String
  context           LegalAcceptanceContext
  acceptedAt        DateTime               @default(now())
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime               @default(now())

  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  document        LegalDocument        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentVersion LegalDocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)

  @@unique([userId, documentVersionId, context])
  @@index([userId, context])
  @@index([documentId])
  @@index([documentVersionId])
}
