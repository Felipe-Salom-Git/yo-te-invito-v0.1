// Prisma schema — Yo Te Invito
// Slice 02: Tenant + User + RBAC
// Slice 02: Tenant + User + RBAC

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PRODUCER_OWNER
  PRODUCER_STAFF
  GASTRO_OWNER
  REFERRER
  SCANNER
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model Tenant {
  id        String    @id @default(cuid())
  name      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users          User[]
  events         Event[]
  orders         Order[]
  ticketScans         TicketScan[]
  ticketScanLogs      TicketScanLog[]
  courtesyGrants    CourtesyGrant[]
  referralLinks     ReferralLink[]
  referralAttributions ReferralAttribution[]
  reviews             Review[]
  auditLogs           AuditLog[]
}

model User {
  id           String      @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String?
  firstName    String
  lastName     String
  phone        String?
  role         Role
  status       UserStatus
  emailVerified DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  courtesyGrants CourtesyGrant[]
  referralLinks  ReferralLink[]
  reviews       Review[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, role])
}

enum EventStatus {
  DRAFT
  PENDING
  APPROVED
  PAUSED
  CANCELLED
}

enum EventMediaType {
  IMAGE
  VIDEO
}

model Event {
  id                String       @id @default(cuid())
  tenantId          String
  producerId        String
  title             String
  description       String?
  startAt           DateTime
  endAt             DateTime?
  city              String?
  venueName         String?
  venueAddress      String?
  geoLat            Float?
  geoLng            Float?
  status            EventStatus  @default(DRAFT)
  capacityTotal     Int?
  coverImageUrl     String?
  isTicketingEnabled Boolean     @default(false)
  ratingAvg         Float?
  ratingCount       Int          @default(0)
  publishedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  media       EventMedia[]
  ticketTypes     TicketType[]
  tickets         Ticket[]
  ticketScans     TicketScan[]
  ticketScanLogs  TicketScanLog[]
  orders           Order[]
  courtesyGrants      CourtesyGrant[]
  referralLinks       ReferralLink[]
  referralAttributions ReferralAttribution[]
  reviews             Review[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, status, deletedAt, startAt])
  @@index([tenantId, city])
}

enum TicketTypeStatus {
  ACTIVE
  PAUSED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CANCELLED
  EXPIRED
  REFUNDED
}

enum TicketStatus {
  VALID
  USED
  REVOKED
}

enum PaymentProvider {
  DEMO
  MERCADOPAGO
  GETNET
}

enum PaymentStatus {
  CREATED
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model TicketType {
  id               String           @id @default(cuid())
  eventId          String
  name             String
  description      String?
  price            Decimal          @db.Decimal(12, 2)
  currency         String           @default("ARS")
  capacityTotal    Int
  capacityAvailable Int
  maxPerOrder      Int              @default(10)
  salesStartAt     DateTime?
  salesEndAt       DateTime?
  status           TicketTypeStatus @default(ACTIVE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  event          Event          @relation(fields: [eventId], references: [id])
  orderItems     OrderItem[]
  tickets        Ticket[]
  courtesyGrants CourtesyGrant[]

  @@index([eventId, status])
}

model Order {
  id              String      @id @default(cuid())
  tenantId        String
  eventId         String
  status          OrderStatus @default(PENDING_PAYMENT)
  buyerEmail      String
  buyerFirstName  String
  buyerLastName   String
  buyerDocument   String?
  totalAmount     Decimal     @db.Decimal(12, 2)
  currency        String      @default("ARS")
  expiresAt       DateTime?
  paidAt          DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  event          Event       @relation(fields: [eventId], references: [id])
  orderItems     OrderItem[]
  tickets        Ticket[]
  payments       Payment[]
  referralLink   ReferralLink?  @relation(fields: [referralLinkId], references: [id])
  referralLinkId String?

  @@index([tenantId, buyerEmail])
  @@index([tenantId, eventId])
  @@index([tenantId, status])
  @@index([expiresAt])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  ticketTypeId String
  quantity     Int
  unitPrice    Decimal  @db.Decimal(12, 2)
  subtotal     Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  order      Order       @relation(fields: [orderId], references: [id])
  ticketType TicketType  @relation(fields: [ticketTypeId], references: [id])
  tickets    Ticket[]
}

enum ScanResult {
  OK
  ALREADY_USED
  INVALID
  REVOKED
}

enum TicketSource {
  ORDER
  COURTESY
}

enum CourtesyMode {
  CONSUMES_BATCH
  FREE_CAPACITY
}

model CourtesyGrant {
  id           String       @id @default(cuid())
  tenantId     String
  eventId      String
  ticketTypeId String?
  mode         CourtesyMode
  quantity     Int
  issued       Int          @default(0)
  note         String?
  createdById  String
  createdAt    DateTime     @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  event       Event       @relation(fields: [eventId], references: [id])
  ticketType  TicketType? @relation(fields: [ticketTypeId], references: [id])
  createdBy   User        @relation(fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([eventId])
}

model Ticket {
  id           String       @id @default(cuid())
  orderId      String?
  orderItemId  String?
  ticketTypeId String?
  eventId      String
  qrPayload    String       @unique
  status       TicketStatus @default(VALID)
  source       TicketSource @default(ORDER)
  usedAt       DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  order       Order?      @relation(fields: [orderId], references: [id])
  orderItem   OrderItem?  @relation(fields: [orderItemId], references: [id])
  ticketType  TicketType? @relation(fields: [ticketTypeId], references: [id])
  event       Event       @relation(fields: [eventId], references: [id])
  ticketScans    TicketScan[]
  ticketScanLogs TicketScanLog[]

  @@index([eventId, status])
  @@index([orderId])
}

model TicketScan {
  id        String   @id @default(cuid())
  tenantId  String
  eventId   String
  ticketId  String?
  qrPayload String
  deviceId  String?
  isValid   Boolean
  reason    String
  createdAt DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  event  Event   @relation(fields: [eventId], references: [id])
  ticket Ticket? @relation(fields: [ticketId], references: [id])

  @@index([tenantId])
  @@index([eventId])
  @@index([ticketId])
}

model TicketScanLog {
  id        String     @id @default(cuid())
  tenantId  String
  eventId   String
  ticketId  String?
  qrPayload String
  deviceId  String?
  scannerId String?
  result    ScanResult
  createdAt DateTime  @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  event  Event   @relation(fields: [eventId], references: [id])
  ticket Ticket? @relation(fields: [ticketId], references: [id])

  @@index([tenantId])
  @@index([eventId])
  @@index([ticketId])
}

model Payment {
  id                String          @id @default(cuid())
  tenantId          String
  orderId           String
  provider          PaymentProvider
  status            PaymentStatus
  amount            Int
  currency          String          @default("ARS")
  externalPaymentId String?
  externalReference String?
  paymentUrl        String?
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([tenantId])
  @@index([orderId])
  @@index([provider])
}

model EventMedia {
  id        String         @id @default(cuid())
  eventId   String
  type      EventMediaType
  url       String
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  deletedAt DateTime?

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
}

model ReferralLink {
  id        String   @id @default(cuid())
  tenantId  String
  eventId   String
  code      String   @unique
  referrerId  String?
  label     String?
  createdAt DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  event     Event     @relation(fields: [eventId], references: [id])
  referrer  User?     @relation(fields: [referrerId], references: [id])
  orders    Order[]
  attributions ReferralAttribution[]

  @@index([tenantId])
  @@index([eventId])
}

model ReferralAttribution {
  id            String   @id @default(cuid())
  tenantId      String
  eventId       String
  referralLinkId String
  orderId       String   @unique
  attributedAt  DateTime @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  event        Event        @relation(fields: [eventId], references: [id])
  referralLink ReferralLink @relation(fields: [referralLinkId], references: [id])

  @@index([tenantId])
  @@index([eventId])
  @@index([referralLinkId])
}

enum AuditAction {
  EVENT_APPROVED
  TICKET_REVOKED
  PAYOUT_STATUS_CHANGED
}

model AuditLog {
  id         String      @id @default(cuid())
  tenantId   String
  actorId    String
  actorRole  String
  action     AuditAction
  entityType String
  entityId   String
  before     Json?
  after      Json?
  metadata   Json?
  createdAt  DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model Review {
  id        String   @id @default(cuid())
  tenantId  String
  eventId   String
  userId    String
  score     Int
  title     String?
  comment   String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  event  Event  @relation(fields: [eventId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([tenantId])
  @@index([eventId])
}
