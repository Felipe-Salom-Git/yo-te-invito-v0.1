// Prisma schema — Yo Te Invito
// Slice 02: Tenant + User + RBAC
// Slice 02: Tenant + User + RBAC

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PRODUCER_OWNER
  PRODUCER_STAFF
  GASTRO_OWNER
  HOTEL_OWNER
  REFERRER
  SCANNER
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

/// Commercial profile that owns a scanner user (V3.1 Etapa 5).
enum ScannerParentProfileType {
  PRODUCER
  GASTRO
  EXCURSION_OPERATOR
  RENTAL_LOCATION
}

enum InboxItemKind {
  GASTRO_PROMOTION_REQUEST
  REVIEW_MODERATION_REQUEST
  REVIEW_DISPUTE_REQUEST
}

enum ReviewDisputeReasonType {
  UNFAIR_RATING
  OFFENSIVE
  FALSE_INFORMATION
  WRONG_EVENT
  OTHER
}

enum ReviewDisputeStatus {
  PENDING
  IN_REVIEW
  ACCEPTED
  REJECTED
  RESOLVED
  CANCELLED
}

enum ReviewPublicStatus {
  VISIBLE
  IN_REVIEW
  HIDDEN
  REPORT_REJECTED
  DELETED_BY_USER
}

enum ReviewReplyAuthorType {
  PRODUCER
  GASTRO_OWNER
  HOTEL_OWNER
  PLATFORM_ADMIN
}

enum InboxItemStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum GastroDiscountType {
  PERCENT
  FIXED
}

enum GastroDiscountStatus {
  PENDING_REVIEW
  COMMISSION_NEGOTIATION
  APPROVED
  ACTIVE
  REJECTED
  CANCELLED
  EXPIRED
}

enum GastroContentType {
  EDITORIAL
  IMAGE
}

enum GastroContentStatus {
  DRAFT
  PUBLISHED
  INACTIVE
}

// ─── Operational profiles (single user + profiles model) ─────────────────────
enum ProfileStatus {
  DRAFT
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
}

enum MembershipRole {
  OWNER
  ADMIN
  STAFF
}

enum MembershipStatus {
  ACTIVE
  PENDING
  DISABLED
}

model Tenant {
  id        String    @id @default(cuid())
  name      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users          User[]
  events         Event[]
  orders         Order[]
  ticketScans         TicketScan[]
  ticketScanLogs      TicketScanLog[]
  courtesyGrants    CourtesyGrant[]
  referralLinks     ReferralLink[]
  referralAttributions ReferralAttribution[]
  referralCommissions ReferralCommission[]
  referralCommercialProposals ReferralCommercialProposal[]
  referralCommercialAgreements ReferralCommercialAgreement[]
  referralPaymentRequests ReferralPaymentRequest[]
  reviews             Review[]
  auditLogs           AuditLog[]
  fraudSignals        FraudSignal[]
  payouts             Payout[]
  platformConfig      PlatformConfig?
  roleApplications    RoleApplication[]
  producerProfiles    ProducerProfile[]
  gastroProfiles      GastroProfile[]
  hotelProfiles       HotelProfile[]
  referrerProfiles    ReferrerProfile[]
  ticketTypes         TicketType[]
  ticketBatches       TicketBatch[]
  ticketTemplates     TicketTemplate[]
  userProducerMemberships UserProducerMembership[]
  userGastroMemberships   UserGastroMembership[]
  userHotelMemberships    UserHotelMembership[]
  userReferrerMemberships UserReferrerMembership[]
  inboxItems              InboxItem[]
  gastroDiscounts         GastroDiscount[]
  gastroDiscountClaims    GastroDiscountClaim[]
  gastroContents          GastroContent[]
  contentSubcategories    ContentSubcategory[]
  contentTags             ContentTag[]
  categoryBannerItems         CategoryBannerItem[]
  categoryEditorialBanners    CategoryEditorialBanner[]
  rentalLocations         RentalLocation[]
  excursionOperators      ExcursionOperator[]
  commercialRelationshipReviews CommercialRelationshipReview[]
  reviewDisputeRequests         ReviewDisputeRequest[]
  userCarts                     UserCart[]
  userFavorites                 UserFavorite[]
  userExpectedEvents            UserExpectedEvent[]
  userProducerFollows           UserProducerFollow[]
  userGastroFollows             UserGastroFollow[]
  userPushSubscriptions         UserPushSubscription[]
  ticketTransferOffers          TicketTransferOffer[]
  userNotifications             UserNotification[]
  notificationDeliveryLogs      NotificationDeliveryLog[]
  legalDocuments                LegalDocument[]
  scannerAccounts               ScannerAccount[]
  eventOccurrences              EventOccurrence[]
  ticketDateChangeRequests      TicketDateChangeRequest[]
}

model RentalLocation {
  id        String    @id @default(cuid())
  tenantId  String
  name          String
  address       String?
  city             String?
  province         String?
  googlePlaceId    String?
  openingHours     Json?
  openingHoursNote String?
  contactPhone     String?
  whatsappPhone    String?
  contactEmail     String?
  websiteUrl       String?
  geoLat           Float?
  geoLng    Float?
  isActive  Boolean   @default(true)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  products Event[]

  @@index([tenantId])
  @@index([tenantId, isActive])
}

model ExcursionOperator {
  id               String    @id @default(cuid())
  tenantId         String
  name             String
  address          String?
  city             String?
  province         String?
  googlePlaceId    String?
  openingHours     Json?
  openingHoursNote String?
  contactPhone     String?
  websiteUrl       String?
  bookingUrl       String?
  socialLinks      Json?
  geoLat           Float?
  geoLng           Float?
  isActive         Boolean   @default(true)
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  tenant     Tenant  @relation(fields: [tenantId], references: [id])
  excursions Event[]

  @@index([tenantId])
  @@index([tenantId, isActive])
}

model ProducerProfile {
  id               String        @id @default(cuid())
  tenantId         String
  slug             String?       @unique
  displayName      String
  legalName        String?
  shortDescription String?
  longDescription  String?
  logoUrl          String?
  coverImageUrl    String?
  galleryUrls      Json?
  primaryPhone     String?
  secondaryPhone   String?
  primaryEmail     String?
  secondaryEmail   String?
  whatsapp         String?
  city             String?
  country          String?
  socialLinks      Json?
  ratingAvg        Float?
  ratingCount      Int           @default(0)
  /// Public profile page views (simple counter; no per-user dedup in V2)
  viewCount        Int           @default(0)
  createdByUserId  String?
  status           ProfileStatus @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant     Tenant                    @relation(fields: [tenantId], references: [id])
  memberships UserProducerMembership[]
  followers   UserProducerFollow[]
  events     Event[]
  referrerRelationships ProducerReferrerRelationship[]
  eventReferrerAssignments EventReferrerAssignment[]
  referralCommercialProposals ReferralCommercialProposal[]
  referralCommercialAgreements ReferralCommercialAgreement[]
  referralPaymentRequestsReceived ReferralPaymentRequest[]
  commercialReviewsReceived CommercialRelationshipReview[] @relation("CommercialReviewProducer")
  reviewDisputeRequests     ReviewDisputeRequest[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model GastroProfile {
  id               String        @id @default(cuid())
  tenantId         String
  displayName      String
  legalName        String?
  summary          String?
  description      String?
  detail           String?
  logoUrl          String?
  bannerUrl        String?
  galleryUrls      Json?
  address          String?
  province         String?
  city             String?
  googlePlaceId    String?
  geoLat           Float?
  geoLng           Float?
  openingHours     Json?
  openingHoursNote String?
  contactPhone     String?
  contactEmail     String?
  menuUrl          String?
  websiteUrl       String?
  bookingUrl       String?
  socialLinks      Json?
  subcategoryId    String?
  publicEventId    String?       @unique
  ratingAvg        Float?
  ratingCount      Int           @default(0)
  createdByUserId  String?
  status           ProfileStatus @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant          Tenant                  @relation(fields: [tenantId], references: [id])
  subcategory     ContentSubcategory?     @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  publicEvent     Event?                  @relation("GastroPublicEvent", fields: [publicEventId], references: [id], onDelete: SetNull)
  memberships     UserGastroMembership[]
  gastroDiscounts GastroDiscount[]
  followers       UserGastroFollow[]
  contentItems    GastroContent[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model GastroContent {
  id              String              @id @default(cuid())
  tenantId        String
  gastroProfileId String
  eventId         String
  type            GastroContentType
  title           String?
  body            String?
  imageUrl        String?
  sortOrder       Int                 @default(0)
  status          GastroContentStatus @default(DRAFT)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  gastroProfile GastroProfile @relation(fields: [gastroProfileId], references: [id], onDelete: Cascade)
  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([tenantId, eventId])
  @@index([gastroProfileId, status, sortOrder])
}

model HotelProfile {
  id              String        @id @default(cuid())
  tenantId        String
  displayName     String
  legalName       String?
  description     String?
  logoUrl         String?
  bannerUrl       String?
  address         String?
  city            String?
  province        String?
  googlePlaceId   String?
  starCategory    Int?
  contactPhone    String?
  contactEmail    String?
  websiteUrl      String?
  bookingUrl      String?
  socialLinks     Json?
  galleryUrls     Json?
  geoLat          Float?
  geoLng          Float?
  whatsappPhone   String?
  amenities       Json?
  publicEventId   String?       @unique
  ratingAvg       Float?
  ratingCount     Int           @default(0)
  createdByUserId String?
  status          ProfileStatus @default(DRAFT)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant      Tenant                 @relation(fields: [tenantId], references: [id])
  publicEvent Event?                 @relation("HotelPublicEvent", fields: [publicEventId], references: [id], onDelete: SetNull)
  memberships UserHotelMembership[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model ReferrerProfile {
  id                    String        @id @default(cuid())
  tenantId              String
  displayName           String
  slug                  String?
  publicHandle          String?
  bio                   String?
  longBio               String?
  avatarUrl             String?
  coverImageUrl         String?
  city                  String?
  region                String?
  publicVisibility      Boolean       @default(false)
  associationLinkToken  String        @unique
  salesScore            Float?
  completedSales        Int           @default(0)
  createdByUserId       String?
  status                ProfileStatus @default(DRAFT)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  tenant     Tenant                     @relation(fields: [tenantId], references: [id])
  memberships UserReferrerMembership[]
  referralLinks ReferralLink[]
  producerRelationships ProducerReferrerRelationship[]
  eventAssignments EventReferrerAssignment[]
  referralCommercialProposals ReferralCommercialProposal[]
  referralCommercialAgreements ReferralCommercialAgreement[]
  referralPaymentRequests ReferralPaymentRequest[]
  commercialReviewsReceived CommercialRelationshipReview[] @relation("CommercialReviewReferrer")

  @@unique([tenantId, slug])
  @@unique([tenantId, publicHandle])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, publicVisibility, status])
}

enum RelationshipStatus {
  PENDING
  ACTIVE
  REJECTED
  BLOCKED
}

enum RelationshipOrigin {
  REQUESTED_BY_REFERRER
  INVITED_BY_PRODUCER
  FREELANCE_CONTACT
  REQUESTED_BY_REFERRER_LINK
  DISCOVERED_IN_FREELANCE_LIST
}

model ProducerReferrerRelationship {
  id                String             @id @default(cuid())
  producerProfileId String
  referrerProfileId String
  status            RelationshipStatus @default(PENDING)
  origin            RelationshipOrigin @default(REQUESTED_BY_REFERRER)
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  producerProfile ProducerProfile @relation(fields: [producerProfileId], references: [id], onDelete: Cascade)
  referrerProfile ReferrerProfile @relation(fields: [referrerProfileId], references: [id], onDelete: Cascade)
  commercialReviews CommercialRelationshipReview[]

  @@unique([producerProfileId, referrerProfileId])
  @@index([producerProfileId])
  @@index([referrerProfileId])
}

enum CommercialReviewTarget {
  PRODUCER
  REFERRER
}

enum CommercialReviewerRole {
  PRODUCER
  REFERRER
}

model CommercialRelationshipReview {
  id                 String                 @id @default(cuid())
  tenantId           String
  relationshipId     String
  producerProfileId  String
  referrerProfileId  String
  reviewerUserId     String
  reviewerRole       CommercialReviewerRole
  targetType         CommercialReviewTarget
  rating             Int
  overallRating      Int?
  aspectRatings      Json?
  comment            String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  tenant           Tenant                      @relation(fields: [tenantId], references: [id])
  relationship     ProducerReferrerRelationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  producerProfile  ProducerProfile             @relation("CommercialReviewProducer", fields: [producerProfileId], references: [id], onDelete: Cascade)
  referrerProfile  ReferrerProfile             @relation("CommercialReviewReferrer", fields: [referrerProfileId], references: [id], onDelete: Cascade)
  reviewer         User                        @relation(fields: [reviewerUserId], references: [id], onDelete: Cascade)

  @@unique([relationshipId, reviewerUserId, targetType])
  @@index([tenantId, producerProfileId])
  @@index([tenantId, referrerProfileId])
  @@index([reviewerUserId])
}

enum EventAssignmentStatus {
  ACTIVE
  PAUSED
  CANCELED
}

model EventReferrerAssignment {
  id                 String                @id @default(cuid())
  eventId            String
  producerProfileId  String
  referrerProfileId  String
  referralLinkId     String?               @unique
  courtesyQuota      Int                   @default(0)
  courtesyUsedCount  Int                   @default(0)
  salesScoreSnapshot Float?
  status             EventAssignmentStatus @default(ACTIVE)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  event           Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  producerProfile ProducerProfile @relation(fields: [producerProfileId], references: [id], onDelete: Cascade)
  referrerProfile ReferrerProfile @relation(fields: [referrerProfileId], references: [id], onDelete: Cascade)
  referralLink    ReferralLink?   @relation(fields: [referralLinkId], references: [id])

  @@unique([eventId, producerProfileId, referrerProfileId])
  @@index([eventId])
  @@index([producerProfileId])
  @@index([referrerProfileId])
}

model UserProducerMembership {
  id           String           @id @default(cuid())
  tenantId     String
  userId       String
  profileId    String
  membershipRole MembershipRole @default(OWNER)
  status       MembershipStatus @default(ACTIVE)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile ProducerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([userId, profileId])
  @@index([tenantId])
  @@index([userId])
  @@index([profileId])
}

model UserGastroMembership {
  id             String           @id @default(cuid())
  tenantId       String
  userId         String
  profileId      String
  membershipRole MembershipRole   @default(OWNER)
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  tenant  Tenant        @relation(fields: [tenantId], references: [id])
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile GastroProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([userId, profileId])
  @@index([tenantId])
  @@index([userId])
  @@index([profileId])
}

model UserHotelMembership {
  id             String           @id @default(cuid())
  tenantId       String
  userId         String
  profileId      String
  membershipRole MembershipRole   @default(OWNER)
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  tenant  Tenant       @relation(fields: [tenantId], references: [id])
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile HotelProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([userId, profileId])
  @@index([tenantId])
  @@index([userId])
  @@index([profileId])
}

model UserReferrerMembership {
  id             String           @id @default(cuid())
  tenantId       String
  userId         String
  profileId      String
  membershipRole MembershipRole   @default(OWNER)
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  tenant  Tenant          @relation(fields: [tenantId], references: [id])
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile ReferrerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([userId, profileId])
  @@index([tenantId])
  @@index([userId])
  @@index([profileId])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model RoleApplication {
  id                String            @id @default(cuid())
  tenantId          String
  email             String
  passwordHash      String
  firstName         String
  lastName          String
  phone             String?
  businessName      String?
  role              Role              // PRODUCER_OWNER | GASTRO_OWNER
  status            ApplicationStatus @default(PENDING)
  createdAt         DateTime          @default(now())
  reviewedAt        DateTime?
  reviewedByUserId  String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([expiresAt])
}

model PlatformConfig {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactEmail    String?
  contactPhone    String?
  contactAddress  String?
  categories      Json?    // [{id: string, label: string}, ...]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id           String      @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String?
  firstName    String
  lastName     String
  phone        String?
  role         Role
  status       UserStatus
  preferences  Json?
  emailVerified DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  courtesyGrants    CourtesyGrant[]
  referralLinks     ReferralLink[]
  referralCommissions ReferralCommission[]
  reviews           Review[]
  ownedTickets       Ticket[]         @relation("TicketOwner")
  transfersFrom      TicketTransfer[] @relation("TransferFromUser")
  transfersTo        TicketTransfer[] @relation("TransferToUser")
  producerMemberships UserProducerMembership[]
  gastroMemberships   UserGastroMembership[]
  hotelMemberships    UserHotelMembership[]
  referrerMemberships UserReferrerMembership[]
  ordersAsBuyer       Order[]                @relation("OrderBuyer")
  inboxItemsCreated   InboxItem[]            @relation("InboxItemCreator")
  inboxItemsResolved  InboxItem[]            @relation("InboxItemResolver")
  reviewsModerated    Review[]               @relation("ReviewModerator")
  reviewsHidden       Review[]               @relation("ReviewHiddenBy")
  gastroDiscountClaims GastroDiscountClaim[]
  commercialRelationshipReviews CommercialRelationshipReview[]
  reviewDisputesRequested       ReviewDisputeRequest[]         @relation("ReviewDisputeRequester")
  reviewDisputesResolved        ReviewDisputeRequest[]         @relation("ReviewDisputeResolver")
  transferOffersSold            TicketTransferOffer[]          @relation("TransferOfferSeller")
  transferOffersBought          TicketTransferOffer[]          @relation("TransferOfferBuyer")
  userCart                      UserCart?
  favorites                     UserFavorite[]
  expectedEvents                UserExpectedEvent[]
  producerFollows               UserProducerFollow[]
  gastroFollows                 UserGastroFollow[]
  pushSubscriptions             UserPushSubscription[]
  notifications                 UserNotification[]
  notificationDeliveries      NotificationDeliveryLog[]
  legalDocumentVersionsPublished LegalDocumentVersion[] @relation("LegalVersionPublisher")
  legalAcceptances              UserLegalAcceptance[]
  scannerAccountAsScanner       ScannerAccount?  @relation("ScannerAccountScanner")
  scannerAccountsManaged        ScannerAccount[] @relation("ScannerAccountParent")
  ticketDateChangeRequests      TicketDateChangeRequest[] @relation("TicketDateChangeRequester")
  ticketDateChangeReviews       TicketDateChangeRequest[] @relation("TicketDateChangeReviewer")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, role])
}

enum EventStatus {
  DRAFT
  PENDING
  APPROVED
  PAUSED
  CANCELLED
}

/// Per-date/show instance for multi-date ticketing events (V3.1 Etapa 7).
enum EventOccurrenceStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum EventMediaType {
  IMAGE
  VIDEO
}

model CategoryBannerItem {
  id        String   @id @default(cuid())
  tenantId  String
  category  String
  eventId   String
  position  Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([tenantId, category, eventId])
  @@index([tenantId, category])
  @@index([tenantId, category, isActive])
}

/// V3.1 Slice 10 — admin-managed editorial hero banners per category (image + title + subtitle).
model CategoryEditorialBanner {
  id             String   @id @default(cuid())
  tenantId       String
  category       String   // event | gastro | rental | excursion
  title          String
  subtitle       String?
  imageUrl       String
  imageObjectKey String?
  ctaLabel       String?
  ctaHref        String?
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, category])
  @@index([tenantId, category, isActive])
  @@index([tenantId, category, sortOrder])
}

model ContentSubcategory {
  id          String   @id @default(cuid())
  tenantId    String
  category    String   // event | gastro | rental | excursion | hotel
  name        String
  slug        String
  description String?
  imageUrl    String?
  iconName    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  events            Event[]
  eventSubcategories EventSubcategory[]
  gastroProfiles    GastroProfile[]

  @@unique([tenantId, category, slug])
  @@index([tenantId, category])
  @@index([tenantId, category, isActive])
}

model EventSubcategory {
  id            String   @id @default(cuid())
  eventId       String
  subcategoryId String
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())

  event       Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  subcategory ContentSubcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)

  @@unique([eventId, subcategoryId])
  @@index([eventId])
  @@index([subcategoryId])
}

/// Tenant-scoped publication tags (V3.1 Etapa 4) — complements categories/subcategories.
model ContentTag {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  slug          String
  description   String?
  /// null = all verticals; otherwise event|gastro|rental|excursion|hotel
  categoryScope String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  eventTags EventTag[]

  @@unique([tenantId, slug])
  @@index([tenantId, isActive])
  @@index([tenantId, categoryScope, isActive])
}

model EventTag {
  id        String   @id @default(cuid())
  eventId   String
  tagId     String
  createdAt DateTime @default(now())

  event Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tag   ContentTag @relation(fields: [tagId], references: [id], onDelete: Restrict)

  @@unique([eventId, tagId])
  @@index([eventId])
  @@index([tagId])
}

model Event {
  id                String       @id @default(cuid())
  tenantId          String
  producerId        String       // LEGACY: kept for compatibility; prefer producerProfileId
  producerProfileId String?      // ownership via ProducerProfile
  category          String?      // event | gastro | excursion | rental | hotel
  subcategoryId     String?
  rentalLocationId    String?
  excursionOperatorId String?
  title             String
  summary           String?
  description       String?
  startAt           DateTime
  endAt             DateTime?
  city              String?
  province          String?
  venueName         String?
  venueAddress      String?
  googlePlaceId     String?
  geoLat            Float?
  geoLng            Float?
  status            EventStatus  @default(DRAFT)
  capacityTotal     Int?
  coverImageUrl     String?
  isTicketingEnabled Boolean     @default(false)
  isGeneralPublication Boolean   @default(false)
  ratingAvg         Float?
  ratingCount       Int          @default(0)
  /// Internal sort metric — never expose on public API responses
  bayesianRating    Float?
  rankingScore      Float?
  /// Public detail page views (simple counter; no per-user dedup in V2)
  viewCount         Int          @default(0)
  publishedAt       DateTime?
  /// Excursion-only schedule text (V3.1 Slice 7) — not used for ticketing events
  excursionDepartureTime    String?
  excursionDurationText     String?
  excursionAvailableDaysText String?
  excursionScheduleNotes    String?
  excursionMeetingPoint     String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  producerProfile ProducerProfile? @relation(fields: [producerProfileId], references: [id], onDelete: SetNull)
  subcategory        ContentSubcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  eventSubcategories EventSubcategory[]
  eventTags          EventTag[]
  rentalLocation     RentalLocation?     @relation(fields: [rentalLocationId], references: [id], onDelete: SetNull)
  excursionOperator  ExcursionOperator?  @relation(fields: [excursionOperatorId], references: [id], onDelete: SetNull)
  media            EventMedia[]
  ticketTypes     TicketType[]
  tickets         Ticket[]
  ticketScans     TicketScan[]
  ticketScanLogs  TicketScanLog[]
  orders           Order[]
  courtesyGrants      CourtesyGrant[]
  referralLinks       ReferralLink[]
  referralAttributions ReferralAttribution[]
  referralCommissions  ReferralCommission[]
  referrerAssignments  EventReferrerAssignment[]
  referralCommercialProposals ReferralCommercialProposal[]
  referralCommercialAgreements ReferralCommercialAgreement[]
  reviews             Review[]
  reviewDisputeRequests ReviewDisputeRequest[]
  fraudSignals        FraudSignal[]
  payouts             Payout[]
  ticketBatches       TicketBatch[]
  gastroDiscounts     GastroDiscount[]
  gastroContents      GastroContent[]
  categoryBannerItems CategoryBannerItem[]
  gastroProfilePublic GastroProfile?       @relation("GastroPublicEvent")
  hotelProfilePublic  HotelProfile?        @relation("HotelPublicEvent")
  userCartItems       UserCartItem[]
  expectedByUsers     UserExpectedEvent[]
  occurrences         EventOccurrence[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, status, deletedAt, startAt])
  @@index([tenantId, city])
  @@index([producerProfileId])
  @@index([subcategoryId])
  @@index([rentalLocationId])
  @@index([excursionOperatorId])
  @@index([tenantId, category, rentalLocationId])
  @@index([tenantId, category, excursionOperatorId])
}

/// Single date/show for a multi-date event. Legacy single-date events use Event.startAt only.
model EventOccurrence {
  id            String                @id @default(cuid())
  tenantId      String
  eventId       String
  startAt       DateTime
  endAt         DateTime?
  venueName     String?
  venueAddress  String?
  city          String?
  province      String?
  googlePlaceId String?
  geoLat        Float?
  geoLng        Float?
  capacity      Int?
  status        EventOccurrenceStatus @default(ACTIVE)
  sortOrder     Int                   @default(0)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketTypes TicketType[]
  orders      Order[]
  orderItems  OrderItem[]
  tickets     Ticket[]
  userCartItems UserCartItem[]
  dateChangesFrom TicketDateChangeRequest[] @relation("DateChangeFromOccurrence")
  dateChangesTo   TicketDateChangeRequest[] @relation("DateChangeToOccurrence")

  @@index([tenantId])
  @@index([eventId])
  @@index([tenantId, eventId])
  @@index([eventId, status, startAt])
  @@index([eventId, sortOrder])
}

