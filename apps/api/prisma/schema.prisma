// Prisma schema — Yo Te Invito
// Slice 02: Tenant + User + RBAC
// Slice 02: Tenant + User + RBAC

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PRODUCER_OWNER
  PRODUCER_STAFF
  GASTRO_OWNER
  REFERRER
  SCANNER
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model Tenant {
  id        String    @id @default(cuid())
  name      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users       User[]
  events      Event[]
  orders      Order[]
  ticketScans TicketScan[]
}

model User {
  id           String      @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String?
  firstName    String
  lastName     String
  phone        String?
  role         Role
  status       UserStatus
  emailVerified DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, role])
}

enum EventStatus {
  DRAFT
  PENDING
  APPROVED
  PAUSED
  CANCELLED
}

enum EventMediaType {
  IMAGE
  VIDEO
}

model Event {
  id                String       @id @default(cuid())
  tenantId          String
  producerId        String
  title             String
  description       String?
  startAt           DateTime
  endAt             DateTime?
  city              String?
  venueName         String?
  venueAddress      String?
  geoLat            Float?
  geoLng            Float?
  status            EventStatus  @default(DRAFT)
  capacityTotal     Int?
  coverImageUrl     String?
  isTicketingEnabled Boolean     @default(false)
  publishedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  media       EventMedia[]
  ticketTypes TicketType[]
  tickets     Ticket[]
  ticketScans TicketScan[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, status, deletedAt, startAt])
  @@index([tenantId, city])
}

enum TicketTypeStatus {
  ACTIVE
  PAUSED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum TicketStatus {
  VALID
  USED
  REVOKED
}

model TicketType {
  id               String           @id @default(cuid())
  eventId          String
  name             String
  description      String?
  price            Decimal          @db.Decimal(12, 2)
  currency         String           @default("ARS")
  capacityTotal    Int
  capacityAvailable Int
  maxPerOrder      Int              @default(10)
  salesStartAt     DateTime?
  salesEndAt       DateTime?
  status           TicketTypeStatus @default(ACTIVE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  event       Event        @relation(fields: [eventId], references: [id])
  orderItems  OrderItem[]
  tickets     Ticket[]

  @@index([eventId, status])
}

model Order {
  id              String      @id @default(cuid())
  tenantId        String
  status          OrderStatus @default(PENDING)
  buyerEmail      String
  buyerFirstName  String
  buyerLastName   String
  buyerDocument   String?
  totalAmount     Decimal     @db.Decimal(12, 2)
  currency        String      @default("ARS")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  orderItems OrderItem[]
  tickets    Ticket[]

  @@index([tenantId, buyerEmail])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  ticketTypeId String
  quantity     Int
  unitPrice    Decimal  @db.Decimal(12, 2)
  subtotal     Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  order      Order       @relation(fields: [orderId], references: [id])
  ticketType TicketType  @relation(fields: [ticketTypeId], references: [id])
  tickets    Ticket[]
}

model Ticket {
  id           String       @id @default(cuid())
  orderId      String
  orderItemId  String
  ticketTypeId String
  eventId      String
  qrPayload    String       @unique
  status       TicketStatus @default(VALID)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  order       Order       @relation(fields: [orderId], references: [id])
  orderItem   OrderItem   @relation(fields: [orderItemId], references: [id])
  ticketType  TicketType  @relation(fields: [ticketTypeId], references: [id])
  event       Event       @relation(fields: [eventId], references: [id])
  ticketScans TicketScan[]

  @@index([eventId, status])
  @@index([orderId])
}

model TicketScan {
  id        String   @id @default(cuid())
  tenantId  String
  eventId   String
  ticketId  String?
  qrPayload String
  deviceId  String?
  isValid   Boolean
  reason    String
  createdAt DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  event  Event   @relation(fields: [eventId], references: [id])
  ticket Ticket? @relation(fields: [ticketId], references: [id])

  @@index([tenantId])
  @@index([eventId])
  @@index([ticketId])
}

model EventMedia {
  id        String         @id @default(cuid())
  eventId   String
  type      EventMediaType
  url       String
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  deletedAt DateTime?

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
}
