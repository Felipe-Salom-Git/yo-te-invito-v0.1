}

enum FavoriteEntityType {
  event
  gastro
  rental
  excursion
  hotel
  discount
}

enum FavoriteProviderType {
  producer
  gastro
  hotel
  excursion_operator
  rental_location
  platform
}

enum PaymentProvider {
